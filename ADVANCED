    job_postings_fact.company_id

SELECT
    company_job_count.company_id,
        company_dim.name,
    company_job_count.job_count,
    CASE
        WHEN job_count < 10 THEN 'SMALL'
        WHEN job_count BETWEEN 10 AND 50 THEN 'MEDIUM'
        ELSE 'LARGE'
        END AS job_open
FROM
    (SELECT
    job_postings_fact.company_id,
    COUNT(job_postings_fact.job_id) AS job_count
FROM
    job_postings_fact
GROUP BY
    job_postings_fact.company_id
) AS company_job_count
LEFT JOIN company_dim
    ON company_job_count.company_id = company_dim.company_id
ORDER BY
job_count DESC;

WITH job_remote AS (
SELECT
    job_id,
    job_title_short,
    CASE
    WHEN job_location = 'Anywhere' THEN 'REMOTE'
    ELSE 'ONSITE'
    END AS job_type
FROM
    job_postings_fact
)

SELECT
    skills_dim.skill_id,
    skills_dim.skills,
    COUNT(skills_dim.skill_id) AS skills_count
FROM 
    job_remote
LEFT JOIN 
    skills_job_dim
ON job_remote.job_id = skills_job_dim.job_id
LEFT JOIN  
    skills_dim
ON skills_job_dim.skill_id = skills_dim.skill_id
WHERE
    job_remote.job_type = 'REMOTE'
    AND job_title_short = 'Data Analyst'
GROUP BY 
    skills_dim.skill_id,
    skills_dim.skills
ORDER BY
    skills_count DESC
LIMIT 5;
